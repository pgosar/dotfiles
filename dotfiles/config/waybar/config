{

    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 40,
    "margin": "0 0 0 0",
    "modules-left": ["custom/launcher", "hyprland/workspaces", "custom/spotify"],
    "modules-center": ["clock", "custom/weather"],
    "modules-right": ["backlight", "pulseaudio", "custom/keyboard-layout", "temperature",
    "cpu", "battery", "tray"],

 // Modules configuration
      "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "active-only": false,
        "format-icons": {
          "default": "’ōā",
          "active": "’æä"
        }
      },
      "custom/spotify": {
      "exec": "/usr/bin/python3 /home/chilly/.config/waybar/scripts/mediaplayer.py",
      "format": "’å╝  {}",
      "max-length": 60,
      "return-type": "json",
      "on-click": "playerctl play-pause",
      "on-scroll-up": "playerctl next",
      "on-scroll-down": "playerctl previous"
    },
    "tray": {
        "icon-size": 16,
        "spacing": 6
    },
    "clock": {
        "format": "’ä│   {:%a %d %b ’ĆŚ %H:%M}",
        "format-alt": "’ä│  {:%d/%m/%Y ’ĆŚ %H:%M:%S}",
        "interval": 1
    },
    "custom/weather": {
        "exec": "~/.config/waybar/scripts/weather.sh",
        "format": "{}",
        "return-type": "json",
        "interval": 1800,
        "tooltip": "true",
        "on-click": "xdg-open https://wttr.in/"
    },
    "cpu": {
        "format": "’ŗø  {usage: >3}%",
        "on-click": "kitty -e bashtop"
    },
    "temperature": {
        "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
        "critical-threshold": 80,
        "format-critical": "{temperatureC}┬░C ’ŗć",
        "format": "’ŗē  {temperatureC}┬░C"
    },
    "backlight": {
        "format": " {percent: >3}%",
        "format-icons": ["’åģ", "¾░āĀ"],
        "on-scroll-down": "brightnessctl -c backlight set 5%-",
        "on-scroll-up": "brightnessctl -c backlight set +5%"
    },
    "battery": {
        "states": {
            "good": 70,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity: >3}%",
        "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"]
    },
    "pulseaudio": {
        "scroll-step": 1,
        "format": "{icon} {volume: >3}%",
        "format-bluetooth": "{icon} {volume: >3}%",
        "format-muted":"¾░Ø¤ muted",
        "format-icons": ["¾░¢Ć", "¾░ĢŠ "],
        "on-click": "pavucontrol",
        "on-scroll-up": "wpctl set-volume -l 5 @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume -l 5 @DEFAULT_AUDIO_SINK@ 5%-"
    },
   "custom/keyboard-layout": {
      	"interval": 1,
      	"format": "’ä£ ",
      	"tooltip": false,
        "on-click": "~/.config/waybar/scripts/openVirtualKeyboard.sh &",
  },
     "custom/launcher": {
    	"format":"’īā ",
    	"on-click": "exec nwg-drawer -c 7 -is 70 -spacing 23",
    	"tooltip": false,
  },
}
