// Niri configuration file
// Migrated from Hyprland config

environment {
    LIBVA_DRIVER_NAME "nvidia"
    __GLX_VENDOR_LIBRARY_NAME "nvidia"
    ELECTRON_OZONE_PLATFORM_HINT "auto"
    XCURSOR_SIZE "24"
}

hotkey-overlay {
    skip-at-startup
}

spawn-at-startup "sh" "-c" "ypridle"
spawn-at-startup "sh" "-c" "hyprpaper"
spawn-at-startup "sh" "-c" "waybar"
spawn-at-startup "sh" "-c" "/usr/lib/hyprpolkitagent/hyprpolkitagent"
spawn-at-startup "sh" "-c" "wl-paste --watch cliphist store"
spawn-at-startup "sh" "-c" "nm-applet"
spawn-at-startup "sh" "-c" "blueman-applet"

output "Microstep MPG321UX OLED 0x01010101" {
    mode "3840x2160@239.99"
    position x=0 y=0
    scale 1.5
}

output "Samsung Electric Company Odyssey G5 HNBY700285" {
    mode "2560x1440@179.95"
    position x=2560 y=0
    scale 1
}

workspace "w10_L" { open-on-output "Microstep MPG321UX OLED 0x01010101"; }
workspace "w10_R" { open-on-output "Samsung Electric Company Odyssey G5 HNBY700285"; }
workspace "w09_L" { open-on-output "Microstep MPG321UX OLED 0x01010101"; }
workspace "w09_R" { open-on-output "Samsung Electric Company Odyssey G5 HNBY700285"; }
workspace "w08_L" { open-on-output "Microstep MPG321UX OLED 0x01010101"; }
workspace "w08_R" { open-on-output "Samsung Electric Company Odyssey G5 HNBY700285"; }
workspace "w07_L" { open-on-output "Microstep MPG321UX OLED 0x01010101"; }
workspace "w07_R" { open-on-output "Samsung Electric Company Odyssey G5 HNBY700285"; }
workspace "w06_L" { open-on-output "Microstep MPG321UX OLED 0x01010101"; }
workspace "w06_R" { open-on-output "Samsung Electric Company Odyssey G5 HNBY700285"; }
workspace "w05_L" { open-on-output "Microstep MPG321UX OLED 0x01010101"; }
workspace "w05_R" { open-on-output "Samsung Electric Company Odyssey G5 HNBY700285"; }
workspace "w04_L" { open-on-output "Microstep MPG321UX OLED 0x01010101"; }
workspace "w04_R" { open-on-output "Samsung Electric Company Odyssey G5 HNBY700285"; }
workspace "w03_L" { open-on-output "Microstep MPG321UX OLED 0x01010101"; }
workspace "w03_R" { open-on-output "Samsung Electric Company Odyssey G5 HNBY700285"; }
workspace "w02_L" { open-on-output "Microstep MPG321UX OLED 0x01010101"; }
workspace "w02_R" { open-on-output "Samsung Electric Company Odyssey G5 HNBY700285"; }
workspace "w01_L" { open-on-output "Microstep MPG321UX OLED 0x01010101"; }
workspace "w01_R" { open-on-output "Samsung Electric Company Odyssey G5 HNBY700285"; }

layout {
    gaps 3 // gaps in = gaps (half inside, half outside), gaps_out is harder to map directly, this applies uniformly.

    struts {
        left 5
        right 5
        top 5
        bottom 5
    }

    focus-ring {
        // Colors populated by apply_theme.py
        width 2
        active-color "#c99282" // fallback
        inactive-color "#211b1caa" // fallback
    }

    border {
        off
    }

    center-focused-column "never"

    default-column-width {}
}

window-rule {
    // Apply to all windows
    geometry-corner-radius 12
    clip-to-geometry true
}

cursor {
    xcursor-size 24
}

input {
    keyboard {
        xkb {
            layout "us"
        }
    }

    touchpad {
        natural-scroll
    }

    mouse {
        // Device specific setup is global for standard mice here, we use follow_mouse approach
    }

    focus-follows-mouse max-scroll-amount="0%"

    // Device overrides removed for now due to syntax issues
}

binds {
    Mod+Q { spawn "kitty"; }
    Mod+C { close-window; }
    Mod+M { quit; }
    Mod+P { spawn "hyprlock"; }
    Mod+Tab { toggle-overview; }
    Mod+Shift+S { spawn "sh" "-c" "HYPRSHOT_DIR=\"$HOME/Pictures/Screenshots/\" hyprshot -m region"; }
    Mod+V { toggle-window-floating; }
    Mod+F { maximize-column; }
    Mod+Shift+F { fullscreen-window; }
    Mod+R { spawn "wofi"; }
    Ctrl+Shift+P { spawn "sh" "-c" "cliphist list | wofi -S dmenu | cliphist decode | wl-copy"; }
    Mod+S { switch-preset-column-width; } // Pseudo/split replacement

    // Focus (Seamless Multi-Monitor Wrap)
    Mod+H { spawn "~/.config/niri/focus_wrap.py" "left"; }
    Mod+L { spawn "~/.config/niri/focus_wrap.py" "right"; }
    Mod+K { focus-window-up; }
    Mod+J { focus-window-down; }

    // Move Window (Seamless Multi-Monitor)
    Mod+Shift+H { move-column-left-or-to-monitor-left; }
    Mod+Shift+L { move-column-right-or-to-monitor-right; }
    Mod+Shift+K { move-window-up-or-to-workspace-up; }
    Mod+Shift+J { move-window-down-or-to-workspace-down; }

    // Column Merging (Manual Quadrant Building)
    Mod+BracketLeft { consume-or-expel-window-left; }
    Mod+BracketRight { consume-or-expel-window-right; }
    Mod+Comma { consume-window-into-column; }
    Mod+Period { expel-window-from-column; }

    // Fine-Grained Resizing
    Mod+Minus { set-window-height "-10%"; }
    Mod+Equal { set-window-height "+10%"; }
    Mod+Shift+Minus { set-column-width "-10%"; }
    Mod+Shift+Equal { set-column-width "+10%"; }


    // Multi-Monitor Focus & Movement
    Mod+Ctrl+H { focus-monitor-left; }
    Mod+Ctrl+L { focus-monitor-right; }
    Mod+Shift+Ctrl+H { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+L { move-column-to-monitor-right; }

    // Workspaces (Synchronized Dual Monitor)
    Mod+1 { spawn "~/.config/niri/workspace_wrap.py" "1"; }
    Mod+2 { spawn "~/.config/niri/workspace_wrap.py" "2"; }
    Mod+3 { spawn "~/.config/niri/workspace_wrap.py" "3"; }
    Mod+4 { spawn "~/.config/niri/workspace_wrap.py" "4"; }
    Mod+5 { spawn "~/.config/niri/workspace_wrap.py" "5"; }
    Mod+6 { spawn "~/.config/niri/workspace_wrap.py" "6"; }
    Mod+7 { spawn "~/.config/niri/workspace_wrap.py" "7"; }
    Mod+8 { spawn "~/.config/niri/workspace_wrap.py" "8"; }
    Mod+9 { spawn "~/.config/niri/workspace_wrap.py" "9"; }
    Mod+0 { spawn "~/.config/niri/workspace_wrap.py" "10"; }

    // Move to Workspace (Intelligent Routing)
    Mod+Shift+1 { spawn "~/.config/niri/move_to_workspace_wrap.py" "1"; }
    Mod+Shift+2 { spawn "~/.config/niri/move_to_workspace_wrap.py" "2"; }
    Mod+Shift+3 { spawn "~/.config/niri/move_to_workspace_wrap.py" "3"; }
    Mod+Shift+4 { spawn "~/.config/niri/move_to_workspace_wrap.py" "4"; }
    Mod+Shift+5 { spawn "~/.config/niri/move_to_workspace_wrap.py" "5"; }
    Mod+Shift+6 { spawn "~/.config/niri/move_to_workspace_wrap.py" "6"; }
    Mod+Shift+7 { spawn "~/.config/niri/move_to_workspace_wrap.py" "7"; }
    Mod+Shift+8 { spawn "~/.config/niri/move_to_workspace_wrap.py" "8"; }
    Mod+Shift+9 { spawn "~/.config/niri/move_to_workspace_wrap.py" "9"; }
    Mod+Shift+0 { spawn "~/.config/niri/move_to_workspace_wrap.py" "10"; }

    // Mouse scroll workspaces (Intercepted for Dual Workspace Safety)
    Mod+WheelScrollDown { spawn "~/.config/niri/workspace_shift_wrap.py" "down"; }
    Mod+WheelScrollUp   { spawn "~/.config/niri/workspace_shift_wrap.py" "up"; }
    Mod+Ctrl+WheelScrollDown { spawn "~/.config/niri/workspace_shift_wrap.py" "down"; }
    Mod+Ctrl+WheelScrollUp   { spawn "~/.config/niri/workspace_shift_wrap.py" "up"; }

    Mod+Ctrl+Down { spawn "~/.config/niri/workspace_shift_wrap.py" "down"; }
    Mod+Ctrl+Up { spawn "~/.config/niri/workspace_shift_wrap.py" "up"; }

    // Media
    XF86AudioRaiseVolume allow-when-locked=true { spawn "wpctl" "set-volume" "-l" "1" "@DEFAULT_AUDIO_SINK@" "5%+"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "5%-"; }
    XF86AudioMute        allow-when-locked=true { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SINK@" "toggle"; }
    XF86AudioMicMute     allow-when-locked=true { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SOURCE@" "toggle"; }
    XF86MonBrightnessUp  allow-when-locked=true { spawn "brightnessctl" "-e4" "-n2" "set" "5%+"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "brightnessctl" "-e4" "-n2" "set" "5%-"; }

    XF86AudioNext        allow-when-locked=true { spawn "playerctl" "next"; }
    XF86AudioPause       allow-when-locked=true { spawn "playerctl" "play-pause"; }
    XF86AudioPlay        allow-when-locked=true { spawn "playerctl" "play-pause"; }
    XF86AudioPrev        allow-when-locked=true { spawn "playerctl" "previous"; }
}

window-rule {
    match app-id=r#"^steam_app_.*$"#
    open-on-output "Microstep MPG321UX OLED 0x01010101"
    open-on-workspace "1"
}

window-rule {
    match app-id=r#"^kitty$"#
    draw-border-with-background false
}

window-rule {
    match app-id=r#"^wofi$"#
    border {
        off
    }
    draw-border-with-background false
    geometry-corner-radius 16
    clip-to-geometry true
}

// Xwayland drags - Niri has specific xwayland issues handling, usually drag fixes are native.
window-rule {
    match is-window-cast-target=true
    // We don't have direct xwayland empty title bypasses exactly like hyprland, this is standard default coverage.
}

// Suppress maximize-events equivalent - Niri handles column bounds mostly organically without explicit suppression.

animations {
    slowdown 1.0

    workspace-switch {
        spring damping-ratio=1.0 stiffness=1000 epsilon=0.0001
    }

    horizontal-view-movement {
        spring damping-ratio=1.0 stiffness=800 epsilon=0.0001
    }

    window-open {
        spring damping-ratio=1.0 stiffness=800 epsilon=0.0001
    }

    window-close {
        spring damping-ratio=1.0 stiffness=800 epsilon=0.0001
    }
}
