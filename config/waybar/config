{
    "layer": "top",
    "position": "top",
    "height": 38,
    "spacing": 8,
    "margin-top": 8,
    "margin-left": 15,
    "margin-right": 15,
    "modules-left": [
        "custom/launcher",
        "group/island-left"
    ],
    "modules-center": [
        "group/island-center"
    ],
    "modules-right": [
        "group/island-right"
    ],
    "group/island-left": {
        "orientation": "horizontal",
        "modules": [
            "hyprland/workspaces",
            "hyprland/window"
        ]
    },
    "group/island-center": {
        "orientation": "horizontal",
        "modules": [
            "custom/spotify",
            "clock"
        ]
    },
    "group/island-right": {
        "orientation": "horizontal",
        "modules": [
            "tray",
            "cpu",
            "temperature",
            "pulseaudio",
            "bluetooth"
        ]
    },
    "custom/launcher": {
        "format": "",
        "on-click": "pkill wofi || wofi --show drun",
        "tooltip": false
    },
    "hyprland/window": {
        "format": "{class}",
        "icon": true,
        "icon-size": 18,
        "max-length": 50
    },
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "active-only": false,
        "format-icons": {
            "default": "󰊠",
            "active": "󰮯"
        },
        "persistent-workspaces": {
            "*": 5
        }
    },
    "custom/spotify": {
        "exec": "/usr/bin/python3 /home/chilly/.config/waybar/scripts/mediaplayer.py",
        "format": "  {}",
        "max-length": 40,
        "return-type": "json",
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous"
    },
    "tray": {
        "icon-size": 16,
        "spacing": 10
    },
    "clock": {
        "format": "  {:%a %d %b %H:%M:%S}",
        "interval": 1
    },
    "cpu": {
        "format": "  {usage: >3}%",
        "on-click": "kitty -e bashtop"
    },
    "temperature": {
        "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
        "critical-threshold": 80,
        "format-critical": " {temperatureC}°C",
        "format": " {temperatureC}°C"
    },
    "bluetooth": {
        "format": "",
        "format-connected": " {device_alias}",
        "format-connected-battery": " {device_alias} {device_battery_percentage}%",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected"
    },
    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon} {volume: >3}%",
        "format-bluetooth": "󰂰 {volume: >3}%",
        "format-muted": "󰝟  Muted",
        "format-icons": [
            "󰕿",
            "󰖀",
            "󰕾"
        ],
        "on-click": "pavucontrol"
    }
}